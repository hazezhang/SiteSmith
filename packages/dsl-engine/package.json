{
  "name": "@sitesmith/dsl-engine",
  "version": "0.1.0",
  "description": "Deterministic Design DSL compiler — 7-dimension design language to CSS/JS. Zero dependencies, LLM-agnostic.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["design-system", "dsl", "css", "compiler", "design-tokens"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hazezhang/SiteSmith.git",
    "directory": "packages/dsl-engine"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
